{
  "style_system": {
    "name": "editorial_slab_contrast",
    "description": "Editorial portfolio style using Breakers Slab for display (H1,H2) and Kulturista for body, links, H3, notes and UI."
  },
  "typography": {
    "display_font": {
      "family": "Breakers Slab",
      "usage": [
        "h1",
        "h2"
      ],
      "characteristics": [
        "slab serif",
        "narrower horizontal proportions",
        "editorial display",
        "tight tracking"
      ],
      "line_height": 1.05,
      "tracking": "-0.02em"
    },
    "body_font": {
      "family": "Kulturista",
      "usage": [
        "body",
        "h3",
        "links",
        "notes",
        "buttons",
        "labels"
      ],
      "characteristics": [
        "slab serif",
        "wider horizontal proportions",
        "comfortable reading",
        "horizontal openness"
      ],
      "line_height": 1.6,
      "tracking": "0em"
    },
    "scale": {
      "h1": "clamp(3rem,7vw,6rem)",
      "h2": "clamp(2.2rem,4vw,3.5rem)",
      "h3": "1.35rem",
      "body": "1rem"
    }
  },
  "colors": {
    "background": "#f4f4f4",
    "panel": "#ffffff",
    "border": "#d9d9d9",
    "text_primary": "#111111",
    "text_secondary": "#6a6a6a",
    "accent_link": "#3366ff"
  },
  "layout": {
    "content_width": "1100px",
    "section_spacing": "6rem",
    "grid_columns": 12,
    "gutter": "1rem"
  },
  "components": {
    "card": {
      "radius": "22px",
      "border": "1px solid #d9d9d9",
      "background": "#ffffff"
    },
    "pill_switcher": {
      "radius": "999px",
      "background": "#eeeeee",
      "active_background": "#ffffff"
    }
  }
}